<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ktdsuniversity.edu.member.dao.MemberDao">
<!-- int selectEmailCount(String email);
    int insertMember(MemberVO memberVO); -->
    <select id="selectEmailCount" parameterType="com.ktdsuniversity.edu.member.vo.MemberVO">
        SELECT COUNT(EMAIL)
		  FROM MEMBERS
		 WHERE EMAIL = #{email}
    </select>
    <insert id="insertMember" parameterType="com.ktdsuniversity.edu.member.vo.MemberVO">
        INSERT INTO MEMBERS 
		 (EMAIL
		, NAME
		, PASSWORD) VALUES 
		 (#{email}
		, #{name}
		, #{password})
    </insert>
</mapper>